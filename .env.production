APP_NAME=CourseEval API
APP_ENV=production
DEBUG=false
HOST=127.0.0.1
PORT=8001

DATABASE_URL=postgresql://courseeval:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/courseeval
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOADS_DIR=/opt/courseeval/shared/uploads

BACKEND_CORS_ORIGINS=https://courseeval.example,https://www.courseeval.example
TRUSTED_HOSTS=courseeval.example,www.courseeval.example,127.0.0.1,localhost

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_ADMIN_PASSWORD
INIT_ADMIN_REAL_NAME=System Administrator
INIT_DEFAULT_DATA=false
ALLOW_PUBLIC_REGISTRATION=false
FRONTEND_ADMIN_BASE_URL=https://www.courseeval.example

GUNICORN_WORKERS=3
LOG_LEVEL=info
ENABLE_LLM_GRADING_WORKER=true
LLM_GRADING_WORKER_LEADER=true
LLM_GRADING_WORKER_POLL_SECONDS=2
LLM_GRADING_TASK_STALE_SECONDS=600
REQUIRE_STRONG_SECRETS=true
