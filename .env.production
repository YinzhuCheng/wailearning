APP_NAME=DD-CLASS API
APP_ENV=production
DEBUG=false
HOST=127.0.0.1
PORT=8001

DATABASE_URL=postgresql://ddclass:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/ddclass
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

BACKEND_CORS_ORIGINS=https://wailearning.xyz,https://www.wailearning.xyz
TRUSTED_HOSTS=wailearning.xyz,www.wailearning.xyz,127.0.0.1,localhost

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_ADMIN_PASSWORD
INIT_ADMIN_REAL_NAME=System Administrator
INIT_DEFAULT_DATA=true

# Optional: inject LLM API key at deploy time for the built-in default preset (first DB insert only).
# DEFAULT_LLM_PRESET_API_KEY is an equivalent alias.
# DEFAULT_LLM_API_KEY=

GUNICORN_WORKERS=3
LOG_LEVEL=info
