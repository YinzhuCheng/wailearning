{
  "version": 1,
  "description": "Machine-readable conservative mapping from changed repository paths to validation targets. This registry drives ops/scripts/dev/select_validation_targets.py. It complements docs/development/TEST_EXECUTION_LEDGER.md; it does not replace the ledger of observed runs.",
  "defaults": {
    "repo_root_placeholder": "<repo>",
    "selection_policy": "conservative",
    "path_matching": "Repository-relative paths with forward slashes. Exact path entries also match descendants when they end with '/'. Glob entries use Python fnmatch semantics."
  },
  "risk_levels": {
    "static": "No runtime product behavior is exercised. Use for docs, tooling, encoding, formatting, and repository hygiene.",
    "targeted": "Focused test target for a bounded product or UI surface.",
    "broad": "Broad target that should be considered when shared harness, shared fixtures, auth, routing, or high-blast-radius files change.",
    "full": "Expensive full validation profile. Use when the changed surface makes target-only evidence too weak."
  },
  "targets": [
    {
      "id": "static.encoding_text_tools",
      "category": "static-check",
      "risk": "static",
      "description": "UTF-8, mojibake-safety, whitespace, and docs/tooling hygiene checks for encoding-sensitive or documentation-only changes.",
      "working_directory": ".",
      "commands": [
        {
          "label": "diff whitespace",
          "argv": ["git", "diff", "--check"]
        },
        {
          "label": "changed text encoding scan",
          "argv": [".venv/Scripts/python.exe", "ops/scripts/dev/check_text_encoding.py", "<changed-text-files>"]
        }
      ],
      "triggers": {
        "paths": [
          ".gitignore",
          "AGENTS.md",
          "README.md",
          "docs/",
          "ops/scripts/windows/set-utf8-session.ps1",
          "ops/scripts/dev/safe_show_text.py",
          "ops/scripts/dev/safe_write_text.py",
          "ops/scripts/dev/check_text_encoding.py"
        ],
        "globs": [
          "*.md",
          "docs/**/*.md",
          "docs/**/*.txt",
          "ops/scripts/dev/*.py",
          "ops/scripts/windows/*.ps1"
        ]
      },
      "ledger_id": "static.encoding_text_tools",
      "notes": "This target is intentionally recommended for docs and text-tooling diffs. It is not a substitute for product tests when source files change."
    },
    {
      "id": "static.validation_selector",
      "category": "static-check",
      "risk": "static",
      "description": "Static validation for the diff-based validation selector and its machine-readable target registry.",
      "working_directory": ".",
      "commands": [
        {
          "label": "compile selector",
          "argv": [".venv/Scripts/python.exe", "-m", "py_compile", "ops/scripts/dev/select_validation_targets.py"]
        },
        {
          "label": "selector smoke",
          "argv": [".venv/Scripts/python.exe", "ops/scripts/dev/select_validation_targets.py", "--paths", "ops/scripts/dev/select_validation_targets.py", "tests/TEST_SELECTION_TARGETS.json", "--json"]
        }
      ],
      "triggers": {
        "paths": [
          "ops/scripts/dev/select_validation_targets.py",
          "tests/TEST_SELECTION_TARGETS.json",
          "docs/development/DEVELOPMENT_AND_TESTING.md",
          "docs/development/TEST_EXECUTION_LEDGER.md",
          "docs/development/TEST_SUITE_MAP.md"
        ],
        "globs": [
          "ops/scripts/dev/select_validation_targets.py",
          "tests/TEST_SELECTION_TARGETS.json"
        ]
      },
      "ledger_id": "static.validation_selector",
      "notes": "First-version target; add a ledger entry after this selector is first committed and observed."
    },
    {
      "id": "static.repo_line_health",
      "category": "static-check",
      "risk": "static",
      "description": "Repository line-health metrics for structure, documentation, test-code, and primary-source trend checks.",
      "working_directory": ".",
      "commands": [
        {
          "label": "line health",
          "argv": [".venv/Scripts/python.exe", "ops/scripts/dev/repo_line_health.py"]
        }
      ],
      "triggers": {
        "paths": [
          "ops/scripts/dev/repo_line_health.py",
          "docs/development/DEVELOPMENT_AND_TESTING.md",
          "docs/reference/CODE_MAP_AND_ENTRYPOINTS.md",
          "docs/development/TEST_EXECUTION_LEDGER.md",
          ".gitignore"
        ],
        "globs": [
          "docs/architecture/REPOSITORY_*.md"
        ]
      },
      "ledger_id": "static.repo_line_health",
      "notes": "Recommended when repository layout, tracking policy, or line-health tooling changes."
    },
    {
      "id": "backend.learning_notes.api",
      "category": "backend-pytest",
      "risk": "targeted",
      "description": "Focused backend API regressions for learning notes, note discussion metadata, and attendance date parsing used by embedded attendance/calendar workflows.",
      "working_directory": ".",
      "commands": [
        {
          "label": "pytest",
          "argv": [".venv/Scripts/python.exe", "-m", "pytest", "tests/backend/learning_notes/test_learning_notes_api.py", "-q"]
        }
      ],
      "triggers": {
        "paths": [
          "tests/backend/learning_notes/test_learning_notes_api.py",
          "apps/backend/wailearning_backend/api/routers/learning_notes.py",
          "apps/backend/wailearning_backend/api/routers/attendance.py",
          "apps/backend/wailearning_backend/api/schemas.py",
          "apps/backend/wailearning_backend/db/models.py",
          "tests/scenarios/llm_scenario.py"
        ],
        "globs": [
          "apps/backend/wailearning_backend/api/routers/learning_notes.py",
          "apps/backend/wailearning_backend/api/routers/attendance.py"
        ]
      },
      "ledger_id": "backend.learning_notes.api",
      "notes": "Pair with the targeted Playwright learning-notes/attendance tier when browser-visible behavior or routing is affected."
    },
    {
      "id": "frontend.admin.build",
      "category": "frontend-build",
      "risk": "targeted",
      "description": "Admin SPA production build. Catches Vue/Vite import, syntax, bundling, and asset pipeline regressions before browser E2E is interpreted.",
      "working_directory": "apps/web/admin",
      "commands": [
        {
          "label": "build",
          "argv": ["npm.cmd", "run", "build"]
        }
      ],
      "triggers": {
        "paths": [
          "apps/web/admin/package.json",
          "apps/web/admin/package-lock.json",
          "apps/web/admin/vite.config.js",
          "apps/web/admin/playwright.config.cjs",
          "apps/web/admin/src/"
        ],
        "globs": [
          "apps/web/admin/src/**",
          "apps/web/admin/*.config.js",
          "apps/web/admin/*.config.cjs"
        ]
      },
      "ledger_id": "frontend.admin.build",
      "notes": "Recommended for admin frontend source/config changes. A Playwright spec-only change does not necessarily require rebuild unless shared helpers or config changed."
    },
    {
      "id": "admin.e2e.learning_notes_attendance_cover_tier20",
      "category": "admin-playwright",
      "risk": "targeted",
      "description": "Targeted admin Playwright tier for learning-note, course-cover, teaching-calendar redirect, and attendance/calendar surfaces.",
      "working_directory": "apps/web/admin",
      "commands": [
        {
          "label": "playwright targeted",
          "argv": ["npx.cmd", "playwright", "test", "e2e-learning-notes-attendance-cover-tier20.spec.js", "--project=chromium"]
        }
      ],
      "triggers": {
        "paths": [
          "tests/e2e/web-admin/e2e-learning-notes-attendance-cover-tier20.spec.js",
          "apps/web/admin/src/views/LearningNotes.vue",
          "apps/web/admin/src/views/Attendance.vue",
          "apps/web/admin/src/views/MyCourses.vue",
          "apps/web/admin/src/views/StudentCourseHome.vue",
          "apps/web/admin/src/router/index.js",
          "apps/backend/wailearning_backend/api/routers/learning_notes.py",
          "apps/backend/wailearning_backend/api/routers/attendance.py"
        ],
        "globs": [
          "apps/web/admin/src/**/LearningNotes*.vue",
          "apps/web/admin/src/**/Attendance*.vue"
        ]
      },
      "ledger_id": "admin.e2e.learning_notes_attendance_cover_tier20",
      "notes": "Does not replace full Playwright when shared E2E harness, auth, global setup, or broad routing changes."
    },
    {
      "id": "backend.llm.attachment_formats",
      "category": "backend-pytest",
      "risk": "targeted",
      "description": "Focused backend attachment extraction and classification tests for text, Office, zip, and RAR handling.",
      "working_directory": ".",
      "commands": [
        {
          "label": "pytest",
          "argv": [".venv/Scripts/python.exe", "-m", "pytest", "tests/backend/llm/test_llm_attachment_formats.py", "-q"]
        }
      ],
      "triggers": {
        "paths": [
          "tests/backend/llm/test_llm_attachment_formats.py",
          "tests/fixtures/llm_rar/",
          "apps/backend/wailearning_backend/domains/llm/attachments.py",
          "apps/backend/wailearning_backend/attachment_compliance.py",
          "apps/backend/wailearning_backend/llm_grading.py"
        ],
        "globs": [
          "tests/fixtures/llm_rar/**",
          "apps/backend/wailearning_backend/domains/llm/**"
        ]
      },
      "ledger_id": "backend.llm.attachment_formats",
      "notes": "If broader LLM grading, quota, or worker behavior changes, add LLM/homework behavior tests beyond this attachment-format target."
    },
    {
      "id": "backend.courses.student_course_roster_behavior",
      "category": "backend-pytest",
      "risk": "targeted",
      "description": "Focused course/roster regression target for student account to roster synchronization, required-course enrollment sync, homework submission access, and class/course invariants.",
      "working_directory": ".",
      "commands": [
        {
          "label": "pytest",
          "argv": [".venv/Scripts/python.exe", "-m", "pytest", "tests/backend/courses/test_student_course_roster_behavior.py", "-q"]
        }
      ],
      "triggers": {
        "paths": [
          "tests/backend/courses/test_student_course_roster_behavior.py",
          "apps/backend/wailearning_backend/domains/courses/access.py",
          "apps/backend/wailearning_backend/domains/roster/reconciliation.py",
          "apps/backend/wailearning_backend/api/routers/auth.py",
          "apps/backend/wailearning_backend/api/routers/homework.py",
          "apps/backend/wailearning_backend/api/routers/subjects.py"
        ],
        "globs": [
          "apps/backend/wailearning_backend/domains/courses/**",
          "apps/backend/wailearning_backend/domains/roster/**",
          "tests/backend/courses/**",
          "tests/backend/roster/**"
        ]
      },
      "ledger_id": "backend.courses.student_course_roster_behavior",
      "notes": "Course access and roster changes often have broad effects. Consider behavior/security tests and PostgreSQL full validation for larger changes."
    },
    {
      "id": "postgres.pytest.package",
      "category": "postgres-pytest",
      "risk": "broad",
      "description": "PostgreSQL-only pytest package for dialect-specific schema, constraint, and transaction behavior.",
      "working_directory": ".",
      "commands": [
        {
          "label": "postgres package pytest",
          "argv": [".venv/Scripts/python.exe", "-m", "pytest", "tests/postgres", "-q"],
          "requires_env": ["TEST_DATABASE_URL"]
        }
      ],
      "triggers": {
        "paths": [
          "tests/postgres/",
          "tests/conftest.py",
          "tests/db_reset.py",
          "ops/scripts/dev/provision_postgres_pytest.sh",
          "apps/backend/wailearning_backend/db/models.py",
          "apps/backend/wailearning_backend/bootstrap.py"
        ],
        "globs": [
          "tests/postgres/**",
          "apps/backend/wailearning_backend/db/**"
        ]
      },
      "ledger_id": "postgres.pytest.package",
      "notes": "The selector can recommend this target but does not provision PostgreSQL. Use the local orchestrator or documented Postgres setup."
    },
    {
      "id": "full.pytest.postgres",
      "category": "full-suite",
      "risk": "full",
      "description": "Full pytest tree under PostgreSQL, intended for release-quality backend validation and zero PostgreSQL-only skips.",
      "working_directory": ".",
      "commands": [
        {
          "label": "postgres full pytest",
          "argv": [".venv/Scripts/python.exe", "-m", "pytest", "tests", "-q"],
          "requires_env": ["TEST_DATABASE_URL"]
        }
      ],
      "triggers": {
        "paths": [
          "tests/conftest.py",
          "tests/db_reset.py",
          "pytest.ini",
          "requirements.txt",
          "apps/backend/wailearning_backend/main.py",
          "apps/backend/wailearning_backend/bootstrap.py",
          "apps/backend/wailearning_backend/db/models.py"
        ],
        "globs": [
          "tests/behavior/**",
          "tests/security/**",
          "tests/postgres/**",
          "apps/backend/wailearning_backend/db/**"
        ]
      },
      "ledger_id": "full.pytest.postgres",
      "notes": "Recommended for high-blast-radius backend, schema, test reset, behavior/security, or release-quality claims. It is expensive and environment-dependent."
    },
    {
      "id": "admin.e2e.full",
      "category": "admin-playwright",
      "risk": "full",
      "description": "Full admin Playwright E2E suite under apps/web/admin. Recommended when shared E2E harness, Playwright config, global setup, seed/reset, auth, or broad frontend routing changes make targeted evidence too weak.",
      "working_directory": "apps/web/admin",
      "commands": [
        {
          "label": "full playwright",
          "argv": ["npm.cmd", "run", "test:e2e"]
        }
      ],
      "triggers": {
        "paths": [
          "apps/web/admin/playwright.config.cjs",
          "tests/e2e/web-admin/global-setup.cjs",
          "tests/e2e/web-admin/fixtures.cjs",
          "tests/e2e/web-admin/future-advanced-coverage-helpers.cjs",
          "apps/backend/wailearning_backend/api/routers/e2e_dev.py",
          "apps/backend/wailearning_backend/main.py",
          "apps/web/admin/src/router/index.js"
        ],
        "globs": [
          "tests/e2e/web-admin/**/*.cjs",
          "tests/e2e/web-admin/**/*.spec.js",
          "apps/web/admin/src/router/**"
        ]
      },
      "ledger_id": null,
      "notes": "The current ledger records targeted Playwright but not a current full admin Playwright run for this branch. Treat this as a high-cost recommendation, not an automatic command to start."
    }
  ],
  "fallback_rules": [
    {
      "id": "docs-only-static",
      "description": "When all changed files are documentation or repository policy files, static checks are normally enough unless the docs claim runtime behavior changed.",
      "if_all_paths_match": [
        "*.md",
        "docs/**",
        "AGENTS.md",
        "README.md",
        ".gitignore"
      ],
      "recommend": ["static.encoding_text_tools"]
    },
    {
      "id": "backend-source-conservative",
      "description": "Unmapped backend source changes should receive at least full PostgreSQL pytest consideration because the selector lacks a precise dependency graph.",
      "if_any_unmatched_path_matches": [
        "apps/backend/wailearning_backend/*.py",
        "apps/backend/wailearning_backend/**/*.py"
      ],
      "recommend": ["full.pytest.postgres"]
    },
    {
      "id": "admin-frontend-conservative",
      "description": "Admin frontend source changes without a more specific Playwright target should receive full Playwright consideration after the build.",
      "if_any_path_matches": [
        "apps/web/admin/src/*",
        "apps/web/admin/src/**"
      ],
      "unless_recommended_categories": ["admin-playwright"],
      "recommend": ["frontend.admin.build", "admin.e2e.full"]
    },
    {
      "id": "playwright-harness-conservative",
      "description": "Any shared Playwright harness/config change should receive full Playwright consideration.",
      "if_any_path_matches": [
        "apps/web/admin/playwright.config.cjs",
        "tests/e2e/web-admin/**/*.cjs"
      ],
      "recommend": ["admin.e2e.full"]
    }
  ]
}
